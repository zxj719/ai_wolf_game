{
  "name": "zhaxiaoji-home",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node node_modules/vite/bin/vite.js",
    "dev:worker": "npx.cmd wrangler dev",
    "build": "node node_modules/vite/bin/vite.js build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "node node_modules/vite/bin/vite.js preview",
    "deploy": "npm exec -- wrangler deploy --assets ./dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "analyze": "node scripts/analyze-games.js",
    "analyze:stats": "node scripts/analyze-games.js --stats",
    "bt:patch": "npm version patch --prefix server && git add server/package.json && git commit -m \"chore: bump bt-server patch version\"",
    "bt:minor": "npm version minor --prefix server && git add server/package.json && git commit -m \"chore: bump bt-server minor version\""
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.4",
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.53.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "jsdom": "^28.0.0",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "vite": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
