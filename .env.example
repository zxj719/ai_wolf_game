# AI API Configuration
# Copy this file to .env and fill in your API key
VITE_API_KEY=your-api-key-here
VITE_API_URL=https://api-inference.modelscope.cn/v1/chat/completions

# Production werewolf AI should use the ECS session proxy instead of browser API keys.
# Put MINIMAX_API_KEY on the ECS host/PM2 environment, not in VITE_* variables.
# VITE_AI_PROVIDER=ecs-session
# VITE_WEREWOLF_AI_MODE=session
